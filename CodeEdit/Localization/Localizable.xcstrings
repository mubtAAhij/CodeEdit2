{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "find-navigator.index-bar.progress": {
      "comment": "Index progress percentage",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Indexing %d%%"
          }
        }
      }
    },
    "find-navigator.index-bar.help": {
      "comment": "Help text explaining the indexing process",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Indexing current workspace files for search. Searches performed while indexing may return incomplete results."
          }
        }
      }
    },
    "find-navigator.toolbar.filter": {
      "comment": "Filter field placeholder text",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Filter"
          }
        }
      }
    },
    "find-navigator.toolbar.filter-help": {
      "comment": "Help text for filter field",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show results with matching text"
          }
        }
      }
    },
    "find_navigator.results_summary": {
      "comment": "Summary of search results showing count of results and files",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%#@results@ in %#@files@"
          },
          "substitutions": {
            "results": {
              "argNum": 1,
              "formatSpecifier": "d",
              "variations": {
                "plural": {
                  "one": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%d result"
                    }
                  },
                  "other": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%d results"
                    }
                  }
                }
              }
            },
            "files": {
              "argNum": 2,
              "formatSpecifier": "d",
              "variations": {
                "plural": {
                  "one": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%d file"
                    }
                  },
                  "other": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%d files"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
