    "find_navigator.results_summary": {
      "comment": "Search results summary",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%#@results@ in %#@files@"
          },
          "substitutions": {
            "results": {
              "argNum": 1,
              "formatSpecifier": "d",
              "variations": {
                "plural": {
                  "one": {
