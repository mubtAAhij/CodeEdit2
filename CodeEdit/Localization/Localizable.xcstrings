{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "find-navigator.indexing-progress": {
      "comment": "Indexing progress percentage shown during workspace search indexing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Indexing %d%%"
          }
        }
      }
    },
    "find-navigator.indexing-help": {
      "comment": "Help text explaining the indexing process and its impact on search results",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Indexing current workspace files for search. Searches performed while indexing may return incomplete results."
          }
        }
      }
    },
    "find-navigator.filter-field-title": {
      "comment": "Placeholder text for the filter field in Find Navigator",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Filter"
          }
        }
      }
    },
    "find-navigator.filter-help": {
