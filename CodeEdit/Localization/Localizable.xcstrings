{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "find-navigator.indexing-progress": {
      "comment": "Progress message shown while indexing workspace files",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Indexing %d%%"
          }
        }
      }
    },
    "find-navigator.indexing-help": {
      "comment": "Help text explaining indexing process",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Indexing current workspace files for search. Searches performed while indexing may return incomplete results."
          }
        }
      }
    },
    "find-navigator.filter-placeholder": {
      "comment": "Placeholder text for find results filter field",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Filter"
          }
        }
      }
    },
