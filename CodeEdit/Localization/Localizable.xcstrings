{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "find-navigator.indexing-progress": {
      "comment": "Shows indexing progress percentage in Find Navigator",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Indexing %d%%"
          }
        }
      }
    },
    "find-navigator.indexing-help": {
      "comment": "Help text explaining search indexing status",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Indexing current workspace files for search. Searches performed while indexing may return incomplete results."
          }
        }
      }
    },
    "find-navigator.filter": {
      "comment": "Filter field placeholder in Find Navigator toolbar",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Filter"
          }
        }
      }
    },
    "find-navigator.filter-help": {
