{
  "version": "1.0",
  "sourceLanguage": "en",
  "strings": {
    "find-navigator.indexing-progress": {
      "comment": "Progress indicator for file indexing in search navigator",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Indexing %d%%"
          }
        }
      }
    },
    "find-navigator.indexing-help": {
      "comment": "Tooltip explaining file indexing process and incomplete results during indexing",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Indexing current workspace files for search. Searches performed while indexing may return incomplete results."
          }
        }
      }
    },
