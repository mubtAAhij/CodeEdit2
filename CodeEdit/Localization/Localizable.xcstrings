    },
    "find_navigator.results_summary": {
      "comment": "Summary showing search results count and file count in Find Navigator",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%#@results@ in %#@files@"
          },
          "substitutions": {
            "results": {
              "argNum": 1,
              "formatSpecifier": "d",
              "variations": {
                "plural": {
                  "one": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%d result"
                    }
                  },
                  "other": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%d results"
                    }
                  }
                }
              }
            },
            "files": {
              "argNum": 2,
              "formatSpecifier": "d",
              "variations": {
                "plural": {
                  "one": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%d file"
                    }
                  },
                  "other": {
                    "stringUnit": {
                      "state": "translated",
                      "value": "%d files"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
